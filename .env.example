# ============================================================================
# ERGOSPHERE - Environment Variables Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================================================
# DJANGO & APP SETTINGS
# ============================================================================
DEBUG=False
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ALLOWED_HOSTS=localhost,127.0.0.1,ergosphere.shubhsomani.tech

# ============================================================================
# DATABASE (SQLite is default; uncomment for PostgreSQL)
# ============================================================================
# For SQLite (default):
# DATABASE_URL=sqlite:///db.sqlite3

# For PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ergosphere
# DB_NAME=ergosphere
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_PORT=5432

# ============================================================================
# LLM & AI SERVICES (Required)
# ============================================================================
# Groq API (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

# Groq Model Configuration
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768

# OpenAI Fallback (optional, only if Groq is rate-limited)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ============================================================================
# SCRAPING CONFIGURATION
# ============================================================================
MAX_PAGES=50
# Time to wait between requests (prevents rate limiting)
SCRAPE_DELAY=1

# ============================================================================
# DATA INITIALIZATION (Optional - for first deployment)
# ============================================================================
# Set to 'true' to automatically run on docker-compose up
# WARNING: Scraping can take 10-30 minutes for 50 pages
INITIALIZE_DATA=false
SCRAPE_BOOKS=false         # Run book scraper on startup
GENERATE_INSIGHTS=false    # Generate AI insights on startup
BUILD_INDEX=false         # Build ChromaDB index on startup
CREATE_SUPERUSER=false     # Create admin superuser on startup

# ============================================================================
# RAG & VECTOR STORE
# ============================================================================
CHROMA_PERSIST_DIR=/app/backend/chroma_db

# ============================================================================
# CORS & FRONTEND
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://frontend:5173,https://yourdomain.com
VITE_API_URL=http://localhost:8000

# ============================================================================
# DOCKER & DEPLOYMENT
# ============================================================================
BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================================
# CACHING
# ============================================================================
CACHE_TIMEOUT=86400
CACHE_LOCATION=/tmp/django_cache

# ============================================================================
# GUNICORN SERVER SETTINGS
# ============================================================================
PORT=8000
GUNICORN_WORKERS=2              # Recommended: 2 * CPU_CORES (single-container, keep low)
GUNICORN_THREADS=2              # Threads per worker
GUNICORN_TIMEOUT=120            # Request timeout (seconds)
COLLECT_STATIC=true             # Collect static files on startup (required for /admin/)

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
