GROQ_API_KEY=
# Primary model to use for AI insights
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
# Comma-separated fallback models tried in order when rate-limited (429)
GROQ_FALLBACK_MODELS=llama-3.1-8b-instant,gemma2-9b-it,mixtral-8x7b-32768

# OpenAI fallback — used only when ALL Groq models are rate-limited (leave blank to disable)
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

MAX_PAGES=50
CHROMA_PERSIST_DIR=./chroma_db
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
